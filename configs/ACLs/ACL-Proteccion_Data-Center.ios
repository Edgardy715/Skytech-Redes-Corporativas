en
conf t

! Limpiar ACL existente antes de aplicar
no ip access-list extended PROTECT-DC

! Definicion de ACL para proteccion del Centro de Datos
ip access-list extended PROTECT-DC
 
 ! --- Servicios Core TCP ---
 permit tcp any 10.64.0.32 0.0.0.31 eq 25
 permit tcp any 10.64.0.32 0.0.0.31 eq 143
 permit tcp any 10.64.0.32 0.0.0.31 eq 80
 permit tcp any 10.64.0.32 0.0.0.31 eq 8080
 permit tcp any 10.64.0.32 0.0.0.31 eq 22
 permit tcp any 10.64.0.32 0.0.0.31 eq 53
 permit tcp any 10.64.0.32 0.0.0.31 range 40000 50000

 ! --- Servicios Core UDP ---
 permit udp any 10.64.0.32 0.0.0.31 eq 53
 permit udp any 10.64.0.32 0.0.0.31 eq 67
 permit udp any 10.64.0.32 0.0.0.31 eq 69
 permit udp any 10.64.0.32 0.0.0.31 eq 1812
 permit udp any 10.64.0.32 0.0.0.31 eq 5060
 permit udp any 10.64.0.32 0.0.0.31 range 10000 20000

 ! --- Trafico Dinamico / Retorno ---
 ! Conexiones TCP establecidas (Retorno de Ansible/SSH)
 permit tcp any 10.64.0.32 0.0.0.31 established
 ! Puertos efimeros UDP para transferencias de datos TFTP
 permit udp any 10.64.0.32 0.0.0.31 gt 1023

 ! --- Control ICMP (Ping) ---
 ! Permitir ICMP Echo desde Mgmt VLAN
 permit icmp 10.64.0.64 0.0.0.15 10.64.0.32 0.0.0.31 echo
 ! Permitir ICMP Echo desde Routers OSPF / Borde
 permit icmp host 10.0.2.129 10.64.0.32 0.0.0.31 echo
 permit icmp host 10.0.2.130 10.64.0.32 0.0.0.31 echo
 permit icmp host 1.0.0.9 10.64.0.32 0.0.0.31 echo

 ! Permitir respuestas ICMP originadas desde los servidores
 permit icmp any 10.64.0.32 0.0.0.31 echo-reply

 ! --- Politica de Bloqueo DC ---
 ! Deny default hacia el segmento de servidores con logging
 deny ip any 10.64.0.32 0.0.0.31 log
 
 ! --- Bypass ---
 ! Permitir trafico restante (Internet / Inter-VLAN)
 permit ip any any
exit

! Aplicacion en la interfaz virtual (SVI)
interface Vlan 100
 ip access-group PROTECT-DC out
exit

do wr