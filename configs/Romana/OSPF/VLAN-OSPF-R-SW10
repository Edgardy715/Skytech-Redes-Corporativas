en
conf t
hostname SW10

! VLANs
vlan 50
 name Atencion_al_Cliente
vlan 60
 name Ventas_Locales
vlan 70
 name Gerencia_Sucursal
exit

! Trunk hacia el Router (e0/0)
interface e0/0
 switchport trunk encapsulation dot1q
 switchport mode trunk
 no shutdown
 exit

! EtherChannel hacia SW11 (LACP — modo Active)
interface range e0/1 - 3
 switchport trunk encapsulation dot1q
 switchport mode trunk
 channel-group 1 mode active
 no shutdown
 exit

interface port-channel 1
 switchport trunk encapsulation dot1q
 switchport mode trunk
 no shutdown
 exit

do wr
