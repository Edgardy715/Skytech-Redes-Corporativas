! 1. Crear el proceso OSPF y ponerle su ID
router ospf 1
 router-id 2.2.2.2
 passive-interface default
 no passive-interface e0/0
 auto-cost reference-bandwidth 10000
exit

! 2. Activar OSPF en el enlace físico hacia el Router
int e0/0
 ip ospf 1 area 0
exit

! 3. Activar OSPF directamente en las VLANs
int range vlan 50, vlan 60, vlan 70
 ip ospf 1 area 0
exit
