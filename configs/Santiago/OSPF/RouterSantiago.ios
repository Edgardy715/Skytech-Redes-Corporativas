en
conf t
! 1. Crear el proceso OSPF y ponerle su ID
router ospf 1
 router-id 5.5.5.5
 passive-interface default
 no passive-interface e0/0
 auto-cost reference-bandwidth 10000
exit

! Anunciar la red interna en OSPF
int range vlan 100, vlan 110, vlan 120
 ip ospf 1 area 0
exit

! Activar OSPF en la interfaz hacia el ISP
int e0/0
 ip ospf 1 area 0
exit
do wr
