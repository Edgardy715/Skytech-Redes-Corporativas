en
conf t

! 1. Permitir la nueva VLAN por la tubería gigante
int port-channel 1
 switchport trunk allowed vlan add 99
exit


! 3. Configurar la IP para hablar con su compañero
int vlan 99
 description Peering_OSPF_RSW1
 ip address 10.255.255.2 255.255.255.252
 ip ospf 1 area 0
 no sh
exit

! 4. Quitarle el bozal a esta VLAN en OSPF
router ospf 1
 no passive-interface vlan 99
exit
do wr