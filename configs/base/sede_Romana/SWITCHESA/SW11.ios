enable
configure terminal
hostname SW11

! CONFIGURACIÓN VTP
vtp domain SKYTECH
vtp mode server
vtp password skytech
vtp version 2

! Trunk hacia SW10 (e0/1, e0/2, e0/3 - para EtherChannel luego)
interface range e0/1 - 3
 switchport trunk encapsulation dot1q
 switchport mode trunk
 no shutdown
 exit

end
write memory
